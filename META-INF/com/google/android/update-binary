#!/sbin/sh

umask 022
OUTFD="$2"
ZIPFILE="$3"

ui_print() {
  echo "$1"
}

require_new_magisk() {
  ui_print "*******************************"
  ui_print " Please install Magisk v20.4+  "
  ui_print "*******************************"
  exit 1
}

mount /data 2>/dev/null

[ -f /data/adb/magisk/util_functions.sh ] || require_new_magisk
. /data/adb/magisk/util_functions.sh

install_module
exit 0
